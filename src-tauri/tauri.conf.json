{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "memoQ Clone",
  "version": "0.1.0",
  "identifier": "com.memoqclone.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "memoQ Clone",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "CAT tool for professional translators",
    "longDescription": "memoQ Clone is a computer-assisted translation (CAT) tool that supports XLIFF import/export, translation memory, and a clean segment editor interface.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "dmg": {
        "background": null,
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "English",
          "Korean"
        ],
        "startMenuFolder": "memoQ Clone",
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "enableElevatedUpdateTask": false,
        "bannerPath": null,
        "dialogImagePath": null
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_OUTPUT_OF_tauri_signer_generate",
      "endpoints": [
        "https://github.com/YOUR_ORG/memoq-clone/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
